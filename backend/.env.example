# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mapbox (used for routing — optional during local dev, distance falls back to haversine)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# OneSignal (optional for MVP)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# Server
PORT=3000
NODE_ENV=development
# Comma-separated allowed origins (leave unset in dev to allow all)
# CORS_ORIGIN=https://your-app.com,https://admin.your-app.com
